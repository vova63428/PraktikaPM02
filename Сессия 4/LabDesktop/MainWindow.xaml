<Window x:Class="LabDesktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:LabDesktop.Views"
        Title="АгроСинтез - Лаборатория" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen" WindowState="Maximized">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Боковое меню -->
        <Grid Grid.Column="0" Background="#2C3E50">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Height="80" Background="#1A252F">
                <StackPanel>
                    <TextBlock Text="АГРОСИНТЕЗ" FontSize="18" FontWeight="Bold" 
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="ЛАБОРАТОРИЯ" FontSize="12" 
                               Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,10">
                    <Button Content="📊 Дашборд" Click="OpenDashboard_Click"
                            Background="Transparent" Foreground="White" FontSize="14" 
                            Height="45" Cursor="Hand" BorderThickness="0"
                            HorizontalAlignment="Stretch" Padding="15,10"/>

                    <Button Content="🏭 Готовая продукция" Click="OpenBatches_Click"
                            Background="Transparent" Foreground="White" FontSize="14" 
                            Height="45" Cursor="Hand" BorderThickness="0"
                            HorizontalAlignment="Stretch" Padding="15,10"/>

                    <Button Content="📦 Сырьё" Click="OpenRawMaterials_Click"
                            Background="Transparent" Foreground="White" FontSize="14" 
                            Height="45" Cursor="Hand" BorderThickness="0"
                            HorizontalAlignment="Stretch" Padding="15,10"/>

                    <Button Content="📜 История" Click="OpenHistory_Click"
                            Background="Transparent" Foreground="White" FontSize="14" 
                            Height="45" Cursor="Hand" BorderThickness="0"
                            HorizontalAlignment="Stretch" Padding="15,10"/>

                    <Separator Margin="10,20" Background="#555"/>

                    <Button Content="🚪 Выход" Click="Logout_Click"
                            Background="Transparent" Foreground="#E74C3C" FontSize="14" 
                            Height="45" Cursor="Hand" BorderThickness="0"
                            HorizontalAlignment="Stretch" Padding="15,10"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Основная область -->
        <Grid Grid.Column="1" Background="#F5F6FA">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>