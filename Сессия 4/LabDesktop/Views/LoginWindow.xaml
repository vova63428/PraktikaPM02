<Window x:Class="LabDesktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация - Лаборатория" Height="480" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Background="#2C3E50">
        <Border Width="380" Height="420" Background="White" CornerRadius="10"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Margin="25">
                <TextBlock Text="АГРОСИНТЕЗ" FontSize="22" FontWeight="Bold" 
                           Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Модуль лаборатории" FontSize="14" 
                           Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <TextBlock Text="Логин" Foreground="#555" Margin="0,0,0,5"/>
                <TextBox x:Name="txtLogin" Height="35" Margin="0,0,0,15" 
                         FontSize="13" Padding="5" Text="lab.vasilieva"/>

                <TextBlock Text="Пароль" Foreground="#555" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword" Height="35" Margin="0,0,0,25" 
                             FontSize="13" Padding="5"/>

                <Button x:Name="btnLogin" Content="ВОЙТИ" Height="40" 
                        Background="#3498DB" Foreground="White" FontSize="14" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand"
                        Click="BtnLogin_Click"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <TextBlock Text="Нет аккаунта?" Foreground="#555" FontSize="12"/>
                    <Button Content="Зарегистрироваться" Background="Transparent" BorderThickness="0" 
                            Foreground="#3498DB" Cursor="Hand" FontSize="12" 
                            Click="BtnRegister_Click" Margin="5,0,0,0"/>
                </StackPanel>

                <TextBlock x:Name="txtError" Text="" Foreground="#E74C3C" 
                           HorizontalAlignment="Center" Margin="0,15,0,0" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>