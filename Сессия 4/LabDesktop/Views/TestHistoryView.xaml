<Page x:Class="LabDesktop.Views.TestHistoryView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="История испытаний">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="300"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White" Padding="15" CornerRadius="8" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="История лабораторных испытаний" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="🔍 Поиск" Background="#3498DB" Foreground="White" 
                            Padding="10,5" Margin="5" Cursor="Hand" Click="Search_Click"/>
                    <Button Content="🔄 Обновить" Background="#3498DB" Foreground="White" 
                            Padding="10,5" Margin="5" Cursor="Hand" Click="Refresh_Click"/>
                    <Button Content="📄 Протокол" Background="#9B59B6" Foreground="White" 
                            Padding="10,5" Margin="5" Cursor="Hand" Click="CreateProtocol_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Фильтр по дате -->
        <Border Grid.Row="1" Background="White" Padding="15" CornerRadius="8" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Дата с:" VerticalAlignment="Center" Margin="5"/>
                <DatePicker x:Name="dpFrom" Width="120" Margin="5"/>
                <TextBlock Text="по:" VerticalAlignment="Center" Margin="5"/>
                <DatePicker x:Name="dpTo" Width="120" Margin="5"/>
            </StackPanel>
        </Border>

        <!-- Таблица истории тестов -->
        <Border Grid.Row="2" Background="White" Padding="10" CornerRadius="8" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="📋 Список всех испытаний" FontWeight="Bold" Margin="0,0,0,10"/>
                <DataGrid x:Name="dgHistory" AutoGenerateColumns="True" IsReadOnly="True"
                          SelectionChanged="DgHistory_SelectionChanged"
                          Height="250" BorderThickness="1" BorderBrush="#DDD"/>
            </StackPanel>
        </Border>

        <!-- Детали выбранной партии -->
        <Border Grid.Row="3" Background="White" Padding="15" CornerRadius="8" Visibility="Collapsed" x:Name="panelDetails" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock x:Name="txtBatchTitle" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                <DataGrid x:Name="dgBatchTests" AutoGenerateColumns="True" IsReadOnly="True" 
                          Height="200" BorderThickness="1" BorderBrush="#DDD"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>