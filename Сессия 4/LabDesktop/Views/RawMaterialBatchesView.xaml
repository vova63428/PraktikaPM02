<Page x:Class="LabDesktop.Views.RawMaterialBatchesView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Контроль сырья">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="15" CornerRadius="8" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Контроль качества сырья" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="🔄 Обновить" Background="#3498DB" Foreground="White" 
                            Padding="10,5" Cursor="Hand" Click="Refresh_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <DataGrid x:Name="dgRawMaterials" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True"/>
    </Grid>
</Page>