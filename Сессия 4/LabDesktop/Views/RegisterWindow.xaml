<Window x:Class="LabDesktop.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация - Лаборатория" Height="640.26" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Background="#2C3E50" Margin="0,0,0,-104">
        <Border Width="380" Height="547" Background="White" CornerRadius="10"
                VerticalAlignment="Center" HorizontalAlignment="Center" Margin="57,29,57,139">
            <StackPanel Margin="25">
                <TextBlock Text="АГРОСИНТЕЗ" FontSize="22" FontWeight="Bold" 
                           Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Регистрация нового пользователя" FontSize="14" 
                           Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <TextBlock Text="Логин" Foreground="#555" Margin="0,0,0,5"/>
                <TextBox x:Name="txtLogin" Height="35" Margin="0,0,0,15" 
                         FontSize="13" Padding="5"/>

                <TextBlock Text="ФИО" Foreground="#555" Margin="0,0,0,5"/>
                <TextBox x:Name="txtFullName" Height="35" Margin="0,0,0,15" 
                         FontSize="13" Padding="5"/>

                <TextBlock Text="Пароль" Foreground="#555" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword" Height="35" Margin="0,0,0,15" 
                             FontSize="13" Padding="5"/>

                <TextBlock Text="Подтверждение пароля" Foreground="#555" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtConfirmPassword" Height="35" Margin="0,0,0,15" 
                             FontSize="13" Padding="5"/>

                <TextBlock Text="Роль" Foreground="#555" Margin="0,0,0,5" Height="13"/>
                <ComboBox x:Name="cbRole" Height="35" Margin="0,0,0,25" FontSize="13">
                    <ComboBoxItem Content="Лаборант" Tag="lab technician" IsSelected="True"/>
                    <ComboBoxItem Content="Администратор" Tag="admin"/>
                </ComboBox>

                <Button x:Name="btnRegister" Content="ЗАРЕГИСТРИРОВАТЬСЯ" Height="40" 
                        Background="#27AE60" Foreground="White" FontSize="14" FontWeight="Bold"
                        BorderThickness="0" Cursor="Hand" Click="BtnRegister_Click"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <TextBlock Text="Уже есть аккаунт?" Foreground="#555" FontSize="12"/>
                    <Button Content="Войти" Background="Transparent" BorderThickness="0" 
                            Foreground="#3498DB" Cursor="Hand" FontSize="12" 
                            Click="BtnLogin_Click" Margin="5,0,0,0"/>
                </StackPanel>

                <TextBlock x:Name="txtError" Text="" Foreground="#E74C3C" 
                           HorizontalAlignment="Center" Margin="0,10,0,0" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>