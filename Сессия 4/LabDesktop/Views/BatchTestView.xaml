<Window x:Class="LabDesktop.Views.BatchTestView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление результата испытания" Height="600" Width="550"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <!-- Партия (ВЫПАДАЮЩИЙ СПИСОК) -->
            <TextBlock Text="Партия:" FontWeight="Bold" Margin="0,0,0,5" FontSize="14"/>
            <ComboBox x:Name="cbBatchNumber" Margin="0,0,0,15" Padding="5" 
                      FontSize="13" Height="35" DisplayMemberPath="batch_number"
                      SelectedValuePath="id" IsEditable="False"/>

            <!-- Наименование параметра -->
            <TextBlock Text="Наименование параметра:" FontWeight="Bold" Margin="0,0,0,5" FontSize="14"/>
            <TextBox x:Name="txtParameterName" Height="35" Margin="0,0,0,15" Padding="8" FontSize="13"/>

            <!-- Нормативное значение -->
            <TextBlock Text="Нормативное значение:" FontWeight="Bold" Margin="0,0,0,5" FontSize="14"/>
            <TextBox x:Name="txtStandardValue" Height="35" Margin="0,0,0,15" Padding="8" FontSize="13"/>

            <!-- Измеренное значение -->
            <TextBlock Text="Измеренное значение:" FontWeight="Bold" Margin="0,0,0,5" FontSize="14"/>
            <TextBox x:Name="txtMeasuredValue" Height="35" Margin="0,0,0,15" Padding="8" FontSize="13"/>

            <!-- Единица измерения -->
            <TextBlock Text="Единица измерения:" FontWeight="Bold" Margin="0,0,0,5" FontSize="14"/>
            <TextBox x:Name="txtUnitOfMeasure" Height="35" Margin="0,0,0,15" Padding="8" FontSize="13" Text="%"/>

            <!-- Комментарий -->
            <TextBlock Text="Комментарий:" FontWeight="Bold" Margin="0,0,0,5" FontSize="14"/>
            <TextBox x:Name="txtComment" Height="80" Margin="0,0,0,20" 
                     TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                     Padding="8" FontSize="13"/>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,10">
                <Button Content="Сохранить" Width="120" Height="40" 
                        Background="#27AE60" Foreground="White" FontSize="14" FontWeight="Bold"
                        Margin="0,0,15,0" Cursor="Hand" Click="BtnSave_Click"/>
                <Button Content="Отмена" Width="120" Height="40" 
                        Background="#7F8C8D" Foreground="White" FontSize="14" FontWeight="Bold"
                        Cursor="Hand" Click="BtnCancel_Click"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>