<Page x:Class="LabDesktop.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Дашборд лаборатории">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="White" Padding="15" CornerRadius="8" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Панель управления лабораторией" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBlock Text="Статистика и сводка по контролю качества" Foreground="#7F8C8D" Margin="0,5,0,15"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="🔄 Обновить" Background="#3498DB" Foreground="White" 
                            Padding="10,5" Cursor="Hand" Click="Refresh_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Карточки статистики -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,15">
            <Border Width="220" Height="120" Background="White" CornerRadius="8" Margin="0,0,15,15" Padding="15">
                <StackPanel>
                    <TextBlock Text="⏳" FontSize="24"/>
                    <TextBlock Text="Ожидают контроля" FontSize="12" Foreground="#7F8C8D"/>
                    <TextBlock x:Name="txtPendingCount" FontSize="28" FontWeight="Bold" Foreground="#F39C12" Text="0"/>
                </StackPanel>
            </Border>

            <Border Width="220" Height="120" Background="White" CornerRadius="8" Margin="0,0,15,15" Padding="15">
                <StackPanel>
                    <TextBlock Text="✅" FontSize="24"/>
                    <TextBlock Text="Выполнено сегодня" FontSize="12" Foreground="#7F8C8D"/>
                    <TextBlock x:Name="txtCompletedToday" FontSize="28" FontWeight="Bold" Foreground="#27AE60" Text="0"/>
                </StackPanel>
            </Border>

            <Border Width="220" Height="120" Background="White" CornerRadius="8" Margin="0,0,15,15" Padding="15">
                <StackPanel>
                    <TextBlock Text="⚠️" FontSize="24"/>
                    <TextBlock Text="Забраковано за неделю" FontSize="12" Foreground="#7F8C8D"/>
                    <TextBlock x:Name="txtRejectedCount" FontSize="28" FontWeight="Bold" Foreground="#E74C3C" Text="0"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Последние испытания -->
        <Border Grid.Row="2" Background="White" Padding="15" CornerRadius="8">
            <StackPanel>
                <TextBlock Text="📋 Последние испытания" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                <DataGrid x:Name="dgRecentTests" AutoGenerateColumns="True" IsReadOnly="True" Height="300"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>