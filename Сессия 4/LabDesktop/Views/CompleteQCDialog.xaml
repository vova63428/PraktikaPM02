<Window x:Class="LabDesktop.Views.CompleteQCDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Завершение контроля качества" Height="420" Width="480"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock x:Name="txtMessage" Grid.Row="0" Text="Выберите решение по партии:" 
                   FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20"/>

        <!-- Выбор решения -->
        <TextBlock Grid.Row="1" Text="Решение:" FontWeight="Bold" Margin="0,0,0,8" FontSize="14"/>
        <ComboBox x:Name="cbDecision" Grid.Row="2" Height="40" Margin="0,0,0,25" FontSize="14">
            <ComboBoxItem Tag="approved" IsSelected="True">✅ Допустить партию</ComboBoxItem>
            <ComboBoxItem Tag="rejected">❌ Забраковать партию</ComboBoxItem>
        </ComboBox>

        <!-- Комментарий -->
        <TextBlock Grid.Row="3" Text="Комментарий (обязательно при браковке):" 
                   FontWeight="Bold" Margin="0,0,0,8" FontSize="14"/>
        <TextBox x:Name="txtComment" Grid.Row="4" Height="90" Margin="0,0,0,30" 
                 TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                 FontSize="13" Padding="8" BorderBrush="#BDC3C7" BorderThickness="1"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Подтвердить" Width="110" Height="38" 
                    Background="#27AE60" Foreground="White" FontSize="14" FontWeight="Bold"
                    Margin="0,0,15,0" Cursor="Hand" Click="BtnOk_Click"/>
            <Button Content="Отмена" Width="110" Height="38" 
                    Background="#7F8C8D" Foreground="White" FontSize="14" FontWeight="Bold"
                    Cursor="Hand" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>