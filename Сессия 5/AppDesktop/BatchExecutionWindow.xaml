<Window x:Class="AppDesktop.BatchExecutionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Аппаратчик - Выполнение партии" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen" WindowState="Maximized">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

       
        <Border Grid.Row="0" Background="#2C3E50" Padding="15" CornerRadius="8" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock x:Name="txtBatchTitle" FontSize="18" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="txtBatchStatus" Foreground="#BDC3C7" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

       
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

           
            <Border Grid.Column="0" Background="White" Padding="15" CornerRadius="8" Margin="0,0,15,0">
                <StackPanel>
                    <TextBlock Text="📋 Маршрут выполнения" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>
                    <ListBox x:Name="lbSteps" Height="400" Margin="0,0,0,15">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="10" Margin="5" CornerRadius="6" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="#DDD"/>
                                            <Setter Property="Background" Value="#FAFAFA"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding status}" Value="completed">
                                                    <Setter Property="Background" Value="#D5F5E3"/>
                                                    <Setter Property="BorderBrush" Value="#27AE60"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding status}" Value="in_progress">
                                                    <Setter Property="Background" Value="#FDEBD0"/>
                                                    <Setter Property="BorderBrush" Value="#F39C12"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding status}" Value="failed">
                                                    <Setter Property="Background" Value="#FADBD8"/>
                                                    <Setter Property="BorderBrush" Value="#E74C3C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock FontWeight="Bold">
                                            <Run Text="{Binding step_number}"/>
                                            <Run Text=". "/>
                                            <Run Text="{Binding step_name}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding status}" FontSize="11" Foreground="#7F8C8D"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <ProgressBar x:Name="progressSteps" Height="20" Margin="0,10,0,0" Foreground="#27AE60" Background="#ECF0F1"/>
                    <TextBlock x:Name="txtProgress" HorizontalAlignment="Center" Margin="0,5,0,0" FontSize="12" Foreground="#7F8C8D"/>
                </StackPanel>
            </Border>

            
            <Border Grid.Column="1" Background="White" Padding="15" CornerRadius="8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="🔧 Текущий шаг" FontWeight="Bold" FontSize="16" Margin="0,0,0,15"/>

                        
                        <Border x:Name="panelDeviation" Background="#FADBD8" Padding="12" CornerRadius="6" Margin="0,0,0,15" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="⚠️ ОТКЛОНЕНИЕ" FontWeight="Bold" Foreground="#E74C3C" FontSize="14"/>
                                <TextBlock x:Name="txtDeviation" TextWrapping="Wrap" Margin="0,5,0,0" Foreground="#C0392B"/>
                            </StackPanel>
                        </Border>

                       
                        <Border Background="#F8F9F9" Padding="12" CornerRadius="6" Margin="0,0,0,15">
                            <StackPanel>
                                <TextBlock x:Name="txtStepName" FontWeight="Bold" FontSize="14"/>
                                <TextBlock x:Name="txtStepDesc" TextWrapping="Wrap" Margin="0,10,0,10" Foreground="#555"/>
                                <TextBlock x:Name="txtStepInstruction" TextWrapping="Wrap" FontStyle="Italic" Foreground="#7F8C8D"/>
                            </StackPanel>
                        </Border>

                        
                        <TextBlock Text="📊 Ожидаемые параметры" FontWeight="Bold" Margin="0,10,0,8"/>
                        <Border Background="#E8F8F5" Padding="12" CornerRadius="6" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="🌡️ Температура" FontSize="11" Foreground="#555"/>
                                    <TextBlock x:Name="txtExpectedTemp" FontSize="16" FontWeight="Bold" Foreground="#2980B9" TextAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="📈 Давление" FontSize="11" Foreground="#555"/>
                                    <TextBlock x:Name="txtExpectedPressure" FontSize="16" FontWeight="Bold" Foreground="#2980B9" TextAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="⚙️ Обороты" FontSize="11" Foreground="#555"/>
                                    <TextBlock x:Name="txtExpectedSpeed" FontSize="16" FontWeight="Bold" Foreground="#2980B9" TextAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                       
                        <TextBlock Text="📝 Фактические параметры" FontWeight="Bold" Margin="0,10,0,8"/>
                        <Border Background="#FEF9E7" Padding="12" CornerRadius="6" Margin="0,0,0,15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="5">
                                    <TextBlock Text="Температура, °C" FontSize="11" Foreground="#555"/>
                                    <TextBox x:Name="txtActualTemp" FontSize="14" Height="35" Margin="0,5,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5">
                                    <TextBlock Text="Давление, бар" FontSize="11" Foreground="#555"/>
                                    <TextBox x:Name="txtActualPressure" FontSize="14" Height="35" Margin="0,5,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="5">
                                    <TextBlock Text="Обороты, rpm" FontSize="11" Foreground="#555"/>
                                    <TextBox x:Name="txtActualSpeed" FontSize="14" Height="35" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        
                        <TextBlock Text="💬 Комментарий (при отклонениях)" FontWeight="Bold" Margin="0,10,0,8"/>
                        <TextBox x:Name="txtComment" Height="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15"/>

                        
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="btnStartStep" Content="▶️ Начать шаг" Width="120" Height="40" 
                                    Background="#3498DB" Foreground="White" Margin="0,0,10,0" Click="BtnStartStep_Click"/>
                            <Button x:Name="btnCompleteStep" Content="✅ Завершить шаг" Width="120" Height="40" 
                                    Background="#27AE60" Foreground="White" Click="BtnCompleteStep_Click"/>
                        </StackPanel>

                       
                        <Border Background="#E8DAEF" Padding="12" CornerRadius="6" Margin="0,15,0,0">
                            <StackPanel>
                                <TextBlock Text="🖥️ ТЕЛЕМЕТРИЯ ЭКСТРУДЕРА" FontWeight="Bold" Foreground="#6C3483"/>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                        <TextBlock Text="Температура" FontSize="10" Foreground="#555"/>
                                        <TextBlock x:Name="txtTeleTemp" FontSize="18" FontWeight="Bold" Foreground="#E74C3C"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                        <TextBlock Text="Давление" FontSize="10" Foreground="#555"/>
                                        <TextBlock x:Name="txtTelePressure" FontSize="18" FontWeight="Bold" Foreground="#E74C3C"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                        <TextBlock Text="Обороты" FontSize="10" Foreground="#555"/>
                                        <TextBlock x:Name="txtTeleSpeed" FontSize="18" FontWeight="Bold" Foreground="#E74C3C"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                                        <TextBlock Text="Вибро" FontSize="10" Foreground="#555"/>
                                        <TextBlock x:Name="txtTeleVibration" FontSize="18" FontWeight="Bold" Foreground="#E74C3C"/>
                                    </StackPanel>
                                </Grid>
                                <TextBlock x:Name="txtTeleTimestamp" FontSize="10" Foreground="#7F8C8D" TextAlignment="Center" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        
        <Border Grid.Row="2" Background="#ECF0F1" Padding="10" CornerRadius="8" Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="🏠 К списку партий" Background="#7F8C8D" Foreground="White" Width="120" Height="35" Click="BtnBack_Click" Margin="0,0,10,0"/>
                <Button Content="🚪 Выход" Background="#E74C3C" Foreground="White" Width="100" Height="35" Click="BtnLogout_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>