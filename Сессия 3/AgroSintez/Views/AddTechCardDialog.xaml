<Window x:Class="AgroSintez.Views.AddTechCardDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание технологической карты" Height="350" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="ID продукта:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtProductId" Grid.Row="1" Height="35" Margin="0,0,0,15" Padding="5" Text="1"/>

        <TextBlock Grid.Row="2" Text="Статус:" FontWeight="Bold" Margin="0,0,0,5"/>
        <ComboBox x:Name="cbStatus" Grid.Row="3" Height="35" Margin="0,0,0,20">
            <ComboBoxItem Tag="draft" IsSelected="True">Черновик</ComboBoxItem>
            <ComboBoxItem Tag="approved">Утверждена</ComboBoxItem>
            <ComboBoxItem Tag="archived">Архивирована</ComboBoxItem>
        </ComboBox>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Создать" Width="100" Height="35" 
                    Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Click="BtnOk_Click"/>
            <Button Content="Отмена" Width="100" Height="35" 
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>