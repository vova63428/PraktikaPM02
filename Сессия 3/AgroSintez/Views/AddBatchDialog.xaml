<Window x:Class="AgroSintez.Views.AddBatchDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление производственной партии" Height="400" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Номер партии:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtBatchNumber" Grid.Row="1" Height="35" Margin="0,0,0,15" Padding="5"/>

        <TextBlock Grid.Row="2" Text="ID заказа:" FontWeight="Bold" Margin="0,0,0,5"/>
        <ComboBox x:Name="cbOrderId" Grid.Row="3" Height="35" Margin="0,0,0,15" 
                  DisplayMemberPath="order_number" SelectedValuePath="id"/>

        <TextBlock Grid.Row="4" Text="Статус:" FontWeight="Bold" Margin="0,0,0,5"/>
        <ComboBox x:Name="cbStatus" Grid.Row="5" Height="35" Margin="0,0,0,20">
            <ComboBoxItem Tag="planned" IsSelected="True">Запланирована</ComboBoxItem>
            <ComboBoxItem Tag="in_progress">В работе</ComboBoxItem>
            <ComboBoxItem Tag="completed">Выполнена</ComboBoxItem>
            <ComboBoxItem Tag="rejected">Забракована</ComboBoxItem>
        </ComboBox>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Добавить" Width="100" Height="35" 
                    Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Click="BtnOk_Click"/>
            <Button Content="Отмена" Width="100" Height="35" 
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>