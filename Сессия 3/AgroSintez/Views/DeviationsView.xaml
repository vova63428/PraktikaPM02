<Page x:Class="AgroSintez.Views.DeviationsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Отклонения">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="15" CornerRadius="8" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Отклонения" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="🔄 Обновить" Style="{StaticResource PrimaryButton}" Click="Refresh_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <DataGrid x:Name="dgDeviations" Grid.Row="1" AutoGenerateColumns="False" 
                  IsReadOnly="True" SelectionMode="Single"
                  CanUserResizeColumns="True"
                  CanUserReorderColumns="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding id}" Width="60"/>
                <DataGridTextColumn Header="ID партии" Binding="{Binding batch_id}" Width="80"/>
                <DataGridTextColumn Header="Шаг" Binding="{Binding step_name}" Width="200"/>
                <DataGridTextColumn Header="Отклонение" Binding="{Binding deviation_description}" Width="*"/>
                <DataGridTextColumn Header="Комментарий" Binding="{Binding operator_comment}" Width="250"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>