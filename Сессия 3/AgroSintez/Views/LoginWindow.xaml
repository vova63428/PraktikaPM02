<Window x:Class="AgroSintez.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация - АгроСинтез" Height="575.361" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Background="#2C3E50" Margin="0,-58,-27,-113">
        <Border Width="420" Height="582" Background="White" CornerRadius="10"
                VerticalAlignment="Center" HorizontalAlignment="Center" Margin="50,70,51,65">
            <StackPanel Margin="25">
                <TextBlock Text="АГРОСИНТЕЗ" FontSize="22" FontWeight="Bold" 
                           Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Модуль технолога" FontSize="14" 
                           Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <TextBlock Text="Логин" Foreground="#555" Margin="0,0,0,5"/>
                <TextBox x:Name="txtLogin" Height="35" Margin="0,0,0,15" 
                         FontSize="13" Padding="5"/>

                <TextBlock Text="Пароль" Foreground="#555" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword" Height="35" Margin="0,0,0,20" 
                             FontSize="13" Padding="5"/>

                <!-- CAPTCHA блок -->
                <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" 
                        Padding="10" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="Введите код с картинки" Foreground="#555" 
                                   Margin="0,0,0,10" FontSize="12"/>

                        <Image x:Name="imgCaptcha" Height="65" Stretch="Uniform"
                               MouseLeftButtonDown="ImgCaptcha_MouseLeftButtonDown"
                               Cursor="Hand" ToolTip="Нажмите для обновления"/>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBox x:Name="txtCaptcha" Height="32" Width="150" 
                                     FontSize="14" Padding="5" MaxLength="6"/>
                            <Button Content="⟳" Width="40" Height="32" Margin="10,0,0,0"
                                    Click="RefreshCaptcha_Click"
                                    ToolTip="Обновить CAPTCHA"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Button x:Name="btnLogin" Content="ВОЙТИ" Height="59" 
                        Style="{StaticResource PrimaryButton}"
                        Click="BtnLogin_Click"/>

                <!-- Кнопка регистрации -->
                <Button Content="Зарегистрироваться" Height="35" Margin="0,10,0,0"
                        Background="Transparent" Foreground="#3498DB" 
                        BorderThickness="0" Cursor="Hand"
                        Click="Register_Click"/>

                <TextBlock x:Name="txtError" Text="" Foreground="#E74C3C" 
                           HorizontalAlignment="Center" Margin="0,15,0,0" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>