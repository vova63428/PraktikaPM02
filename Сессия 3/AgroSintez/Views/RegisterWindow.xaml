<Window x:Class="AgroSintez.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация - АгроСинтез" Height="550" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Background="#2C3E50">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Border Width="450" Background="White" CornerRadius="10"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                <StackPanel Margin="25">
                    <TextBlock Text="АГРОСИНТЕЗ" FontSize="22" FontWeight="Bold" 
                               Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                    <TextBlock Text="Регистрация нового пользователя" FontSize="14" 
                               Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                    <!-- Логин -->
                    <TextBlock Text="Логин" Foreground="#555" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtLogin" Height="35" Margin="0,0,0,15" 
                             FontSize="13" Padding="5"/>

                    <!-- ФИО -->
                    <TextBlock Text="ФИО" Foreground="#555" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtFullName" Height="35" Margin="0,0,0,15" 
                             FontSize="13" Padding="5"/>

                    <!-- Пароль -->
                    <TextBlock Text="Пароль" Foreground="#555" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtPassword" Height="35" Margin="0,0,0,15" 
                                 FontSize="13" Padding="5"/>

                    <!-- Подтверждение пароля -->
                    <TextBlock Text="Подтверждение пароля" Foreground="#555" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="txtConfirmPassword" Height="35" Margin="0,0,0,20" 
                                 FontSize="13" Padding="5"/>

                    <!-- CAPTCHA блок -->
                    <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" 
                            Padding="10" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="Введите код с картинки" Foreground="#555" 
                                       Margin="0,0,0,10" FontSize="12"/>

                            <Image x:Name="imgCaptcha" Height="65" Stretch="Uniform"
                                   MouseLeftButtonDown="ImgCaptcha_MouseLeftButtonDown"
                                   Cursor="Hand" ToolTip="Нажмите для обновления"/>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <TextBox x:Name="txtCaptcha" Height="32" Width="150" 
                                         FontSize="14" Padding="5"/>
                                <Button Content="⟳" Width="40" Height="32" Margin="10,0,0,0"
                                        Click="RefreshCaptcha_Click"
                                        ToolTip="Обновить CAPTCHA"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Кнопка регистрации -->
                    <Button x:Name="btnRegister" Content="ЗАРЕГИСТРИРОВАТЬСЯ" Height="40" 
                            Background="#27AE60" Foreground="White" FontSize="14" 
                            FontWeight="Bold" BorderThickness="0" Cursor="Hand"
                            Click="BtnRegister_Click"/>

                    <!-- Кнопка назад -->
                    <Button Content="Назад к входу" Height="35" Margin="0,10,0,0"
                            Background="Transparent" Foreground="#3498DB" 
                            BorderThickness="0" Cursor="Hand"
                            Click="BackToLogin_Click"/>

                    <!-- Сообщение об ошибке -->
                    <TextBlock x:Name="txtError" Text="" Foreground="#E74C3C" 
                               HorizontalAlignment="Center" Margin="0,15,0,0" FontSize="12"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>