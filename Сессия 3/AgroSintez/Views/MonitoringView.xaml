<Page x:Class="AgroSintez.Views.MonitoringView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Мониторинг">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="15" CornerRadius="8" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Мониторинг выполнения партий" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBlock Text="Отслеживание активных производственных партий" Foreground="#7F8C8D" Margin="0,5,0,15"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="🔄 Обновить" Style="{StaticResource PrimaryButton}" Click="Refresh_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" Padding="15" CornerRadius="8" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Активные партии" FontWeight="Bold" Margin="0,0,0,10"/>
                <ListView x:Name="lvBatches" SelectionChanged="LvBatches_SelectionChanged" Height="150">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Номер партии" Width="150" DisplayMemberBinding="{Binding batch_number}"/>
                            <GridViewColumn Header="Статус" Width="120" DisplayMemberBinding="{Binding status}"/>
                            <GridViewColumn Header="Факт, кг" Width="100" DisplayMemberBinding="{Binding actual_quantity_kg}"/>
                            <GridViewColumn Header="Время старта" Width="150" DisplayMemberBinding="{Binding start_time}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="White" Padding="15" CornerRadius="8">
            <StackPanel>
                <TextBlock x:Name="txtSelectedBatch" Text="Выберите партию для просмотра шагов" FontWeight="Bold" Margin="0,0,0,10"/>
                <DataGrid x:Name="dgSteps" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№" Binding="{Binding step_number}" Width="50"/>
                        <DataGridTextColumn Header="Наименование шага" Binding="{Binding step_name}" Width="200"/>
                        <DataGridTextColumn Header="План T°C" Binding="{Binding planned_temperature}" Width="80"/>
                        <DataGridTextColumn Header="Факт T°C" Binding="{Binding actual_temperature}" Width="80"/>
                        <DataGridTextColumn Header="Отклонение" Binding="{Binding has_deviation}" Width="80"/>
                        <DataGridTextColumn Header="Описание" Binding="{Binding deviation_description}" Width="250"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding end_time}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Border>
    </Grid>
</Page>