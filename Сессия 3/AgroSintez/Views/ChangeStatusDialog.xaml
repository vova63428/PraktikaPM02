<Window x:Class="AgroSintez.Views.ChangeStatusDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Изменение статуса рецептуры" Height="250" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Рецептура:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBlock x:Name="txtRecipeName" Grid.Row="1" Margin="0,0,0,15" FontSize="14"/>

        <TextBlock Grid.Row="2" Text="Новый статус:" FontWeight="Bold" Margin="0,0,0,5"/>
        <ComboBox x:Name="cbStatus" Grid.Row="3" Height="35" Margin="0,0,0,20">
            <ComboBoxItem Tag="active" IsSelected="True">Активна</ComboBoxItem>
            <ComboBoxItem Tag="draft">Черновик</ComboBoxItem>
            <ComboBoxItem Tag="archived">Архивирована</ComboBoxItem>
        </ComboBox>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" Width="100" Height="35" 
                    Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Click="BtnOk_Click"/>
            <Button Content="Отмена" Width="100" Height="35" 
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>