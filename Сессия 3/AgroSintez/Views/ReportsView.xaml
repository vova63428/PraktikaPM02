<Page x:Class="AgroSintez.Views.ReportsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Отчеты">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="15" CornerRadius="8" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Формирование отчетных материалов" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                    <Button Content="📊 Отчет по рецептурам" Style="{StaticResource PrimaryButton}" 
                            Click="RecipesReport_Click" Margin="0,0,10,0"/>
                    <Button Content="📈 Отчет по производству" Style="{StaticResource PrimaryButton}" 
                            Click="ProductionReport_Click" Margin="0,0,10,0"/>
                    <Button Content="⚠️ Отчет по отклонениям" Style="{StaticResource PrimaryButton}" 
                            Click="DeviationsReport_Click" Margin="0,0,10,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" Padding="15" CornerRadius="8">
            <StackPanel>
                <TextBlock x:Name="txtReportTitle" Text="Выберите тип отчета" FontSize="16" FontWeight="Bold" 
                           Foreground="#2C3E50" Margin="0,0,0,15"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="txtReportContent" Text="..." TextWrapping="Wrap" 
                               FontFamily="Consolas" FontSize="12"/>
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</Page>