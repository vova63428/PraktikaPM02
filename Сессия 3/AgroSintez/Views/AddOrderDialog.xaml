<Window x:Class="AgroSintez.Views.AddOrderDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание производственного заказа" Height="450" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Рецептура:" FontWeight="Bold" Margin="0,0,0,5"/>
        <ComboBox x:Name="cbRecipe" Grid.Row="1" Height="35" Margin="0,0,0,15" 
                  DisplayMemberPath="name" SelectedValuePath="id"/>

        <TextBlock Grid.Row="2" Text="Технологическая карта:" FontWeight="Bold" Margin="0,0,0,5"/>
        <ComboBox x:Name="cbTechCard" Grid.Row="3" Height="35" Margin="0,0,0,15" 
                  DisplayMemberPath="id" SelectedValuePath="id"/>

        <TextBlock Grid.Row="4" Text="Плановое количество (кг):" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox x:Name="txtQuantity" Grid.Row="5" Height="35" Margin="0,0,0,15" Text="1000" Padding="5"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Создать" Width="100" Height="35" 
                    Style="{StaticResource PrimaryButton}" Margin="0,0,10,0" Click="BtnOk_Click"/>
            <Button Content="Отмена" Width="100" Height="35" 
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>