<Window x:Class="AgroSintez.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:AgroSintez.Views"
        Title="АгроСинтез - Модуль технолога" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen" WindowState="Maximized">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#2C3E50">
            <StackPanel>
                <Border Height="80" Background="#1A252F">
                    <TextBlock Text="АГРОСИНТЕЗ" FontSize="18" FontWeight="Bold" 
                               Foreground="White" HorizontalAlignment="Center" 
                               VerticalAlignment="Center"/>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,10">
                        <Button Style="{StaticResource MenuButton}" Click="OpenProducts_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📦 " FontSize="16"/>
                                <TextBlock Text="Продукция" FontSize="14"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource MenuButton}" Click="OpenRecipes_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋 " FontSize="16"/>
                                <TextBlock Text="Рецептуры" FontSize="14"/>
                            </StackPanel>
                        </Button>

                        <!-- НОВАЯ КНОПКА: Технологические карты -->
                        <Button Style="{StaticResource MenuButton}" Click="OpenTechCards_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙️ " FontSize="16"/>
                                <TextBlock Text="Технологические карты" FontSize="14"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource MenuButton}" Click="OpenOrders_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊 " FontSize="16"/>
                                <TextBlock Text="Производственные заказы" FontSize="14"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource MenuButton}" Click="OpenBatches_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏭 " FontSize="16"/>
                                <TextBlock Text="Партии" FontSize="14"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource MenuButton}" Click="OpenMonitoring_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📈 " FontSize="16"/>
                                <TextBlock Text="Мониторинг" FontSize="14"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource MenuButton}" Click="OpenExtruder_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔧 " FontSize="16"/>
                                <TextBlock Text="Настройка экструдера" FontSize="14"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource MenuButton}" Click="OpenDeviations_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠️ " FontSize="16"/>
                                <TextBlock Text="Отклонения" FontSize="14"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource MenuButton}" Click="OpenReports_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📄 " FontSize="16"/>
                                <TextBlock Text="Отчеты" FontSize="14"/>
                            </StackPanel>
                        </Button>

                        <Separator Margin="10,20" Background="#555"/>

                        <Button Style="{StaticResource MenuButton}" Click="Logout_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🚪 " FontSize="16"/>
                                <TextBlock Text="Выход" FontSize="14" Foreground="#E74C3C"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Background="#F5F6FA">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>