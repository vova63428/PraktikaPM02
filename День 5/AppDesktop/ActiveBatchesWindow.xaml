<Window x:Class="AppDesktop.ActiveBatchesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Аппаратчик - Активные партии" Height="650" Width="1200"
        WindowStartupLocation="CenterScreen" WindowState="Normal">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="20" CornerRadius="10" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="АКТИВНЫЕ ПАРТИИ" FontSize="22" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Выберите партию для выполнения технологического процесса" FontSize="14" Foreground="#BDC3C7" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <!-- Список партий -->
        <Border Grid.Row="1" Background="White" Padding="15" CornerRadius="10" Margin="0,0,0,20">
            <DataGrid x:Name="dgBatches" AutoGenerateColumns="False" 
                      IsReadOnly="True" SelectionMode="Single"
                      SelectionChanged="DgBatches_SelectionChanged"
                      BorderThickness="1" BorderBrush="#DDD"
                      FontSize="14" RowHeight="55"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">

                <!-- Цветовая индикация строк -->
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding status}" Value="in_progress">
                                <Setter Property="Background" Value="#FDEBD0"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding status}" Value="planned">
                                <Setter Property="Background" Value="#E8F8F5"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding status}" Value="completed">
                                <Setter Property="Background" Value="#D5F5E3"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <!-- Колонки с русскими заголовками и фиксированной шириной -->
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding id}" Width="60"/>
                    <DataGridTextColumn Header="Номер партии" Binding="{Binding batch_number}" Width="160" FontWeight="Bold"/>
                    <DataGridTextColumn Header="Продукт" Binding="{Binding product_name}" Width="280"/>
                    <DataGridTextColumn Header="Линия" Binding="{Binding line_number}" Width="80"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding status}" Width="120"/>
                    <DataGridTextColumn Header="Текущий шаг" Binding="{Binding current_step_number}" Width="100"/>
                    <DataGridTextColumn Header="Всего шагов" Binding="{Binding total_steps}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Нижняя панель -->
        <Border Grid.Row="2" Background="#ECF0F1" Padding="15" CornerRadius="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="🔄 ОБНОВИТЬ" Background="#3498DB" Foreground="White" 
                        Width="130" Height="40" FontSize="13" FontWeight="Bold"
                        Margin="0,0,15,0" Cursor="Hand" Click="Refresh_Click"/>
                <Button Content="🚪 ВЫХОД" Background="#E74C3C" Foreground="White" 
                        Width="130" Height="40" FontSize="13" FontWeight="Bold"
                        Cursor="Hand" Click="Logout_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>