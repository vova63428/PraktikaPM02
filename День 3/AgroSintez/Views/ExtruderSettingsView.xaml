<Page x:Class="AgroSintez.Views.ExtruderSettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Настройка экструдера">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="15" CornerRadius="8" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Настройка программ загрузки экструдера" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBlock Text="Экструдер EK-45" Foreground="#7F8C8D" Margin="0,5,0,15"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" Padding="15" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Температура зон (°C):" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="txtTemperature" Grid.Row="0" Grid.Column="1" Height="30" Margin="5" Text="75-85"/>
                <TextBlock Text="Рекомендуемая температура экструзии" Grid.Row="0" Grid.Column="2" Foreground="Gray" Margin="5" VerticalAlignment="Center"/>

                <TextBlock Text="Давление (атм):" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="txtPressure" Grid.Row="1" Grid.Column="1" Height="30" Margin="5" Text="2.5-3.5"/>
                <TextBlock Text="Давление в экструдере" Grid.Row="1" Grid.Column="2" Foreground="Gray" Margin="5" VerticalAlignment="Center"/>

                <TextBlock Text="Скорость шнека (об/мин):" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                <TextBox x:Name="txtScrewSpeed" Grid.Row="2" Grid.Column="1" Height="30" Margin="5" Text="300-450"/>
                <TextBlock Text="При увеличении скорости растет производительность" Grid.Row="2" Grid.Column="2" Foreground="Gray" Margin="5" VerticalAlignment="Center"/>

                <TextBlock Text="Профиль загрузки:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="5"/>
                <ComboBox x:Name="cbProfile" Grid.Row="3" Grid.Column="1" Height="30" Margin="5">
                    <ComboBoxItem Content="Стандартный"/>
                    <ComboBoxItem Content="Высокая производительность"/>
                    <ComboBoxItem Content="Экономичный"/>
                </ComboBox>

                <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" 
                            HorizontalAlignment="Right" Margin="0,30,0,0">
                    <Button Content="Загрузить параметры" Style="{StaticResource PrimaryButton}" Click="LoadSettings_Click" Margin="0,0,10,0"/>
                    <Button Content="Сохранить" Style="{StaticResource PrimaryButton}" Click="SaveSettings_Click" Margin="0,0,10,0"/>
                    <Button Content="Отправить на экструдер" Style="{StaticResource PrimaryButton}" Click="SendToExtruder_Click" Background="#F39C12"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>