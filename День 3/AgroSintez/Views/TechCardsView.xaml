<Page x:Class="AgroSintez.Views.TechCardsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Технологические карты">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" Padding="15" CornerRadius="8" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Технологические карты" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                <TextBlock Text="Управление технологическими картами" Foreground="#7F8C8D" Margin="0,5,0,15"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="➕ Создать" Style="{StaticResource PrimaryButton}" Click="CreateTechCard_Click" Margin="0,0,10,0"/>
                    <Button Content="✅ Утвердить" Style="{StaticResource PrimaryButton}" Click="ApproveTechCard_Click" Margin="0,0,10,0"/>
                    <Button Content="🔄 Обновить" Style="{StaticResource PrimaryButton}" Click="Refresh_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <DataGrid x:Name="dgTechCards" Grid.Row="1" AutoGenerateColumns="True" 
                  IsReadOnly="True" SelectionMode="Single"
                  CanUserResizeColumns="True"
                  CanUserReorderColumns="True"/>
    </Grid>
</Page>